# Admin

susanoo.{$ADMIN_DOMAIN} {
    import cloudflare
    import log_common
    reverse_proxy https://susanoo.van-tetra.ts.net:8006 {
}

eurus.{$ADMIN_DOMAIN} {
    import cloudflare
    reverse_proxy https://eurus:8006 {
        transport http {
                tls
                tls_insecure_skip_verify
        }
    }
}

