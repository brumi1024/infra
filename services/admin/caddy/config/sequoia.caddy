zephyrus.connectionlost.dev {
    import cloudflare
    import headers
    reverse_proxy zephyrus:5000
}

frigate.seq.connectionlost.dev {
    import authenticate
    import cloudflare
    import headers
    reverse_proxy https://argestes:8971 {
        transport http {
                tls
                tls_insecure_skip_verify
        }
    }
}